{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git worktree*)",
      "Bash(npm test*)",
      "Bash(npm run*)",
      "Bash(npx*)",
      "Bash(node*)",
      "Bash(python3*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(echo*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(chmod*)",
      "Bash(ccusage*)",
      "Bash(tailscale status)",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/*credentials*)",
      "Read(**/*_token*)",
      "Read(**/*api_key*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git push --force*)",
      "Bash(sudo *)",
      "Bash(npm install*)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(git worktree remove*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/framework/.local/bin/ccbot hook",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "docs.claude.com",
        "docs.anthropic.com",
        "www.anthropic.com",
        "api.anthropic.com",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "community.n8n.io",
        "docs.n8n.io",
        "developers.notion.com",
        "api.notion.com",
        "core.telegram.org",
        "api.telegram.org",
        "ollama.com",
        "ai.google.dev",
        "generativelanguage.googleapis.com",
        "api.groq.com",
        "docs.docker.com",
        "tailscale.com",
        "npmjs.com",
        "registry.npmjs.org",
        "pypi.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "$PWD/**"
      ],
      "denyRead": [
        ".env",
        ".env.*",
        "**/*.pem",
        "**/*.key",
        "**/secrets/**"
      ]
    }
  },
  "theme": "dark"
}
